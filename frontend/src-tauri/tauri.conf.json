{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMVerge",
  "version": "0.1.0",
   "identifier": "com.amiri.amverge",
   "mainBinaryName": "AMVerge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
         "title": "AMVerge",
        "minWidth": 920,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
     "windows": {
       "nsis": {
         "installerIcon": "icons/amverge-mini-logo.ico",
         "startMenuFolder": "AMVerge"
       }
     },
    "resources": [
      "bin/backend_script-x86_64-pc-windows-msvc/backend_script.exe",
      "bin/backend_script-x86_64-pc-windows-msvc/_internal/**/*",
      "bin/ffmpeg.exe",
      "bin/ffprobe.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/amverge-mini-logo.ico"
    ]
  }
}
