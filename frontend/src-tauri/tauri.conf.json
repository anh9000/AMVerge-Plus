{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMVerge Plus",
  "version": "0.5.0",
  "identifier": "com.amiri.amverge",
  "mainBinaryName": "AMVerge Plus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AMVerge Plus",
        "minWidth": 920,
        "minHeight": 540,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; media-src 'self' asset: https://asset.localhost blob:; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/com.amiri.amverge/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/amverge-mini-logo.ico",
        "startMenuFolder": "AMVerge Plus"
      }
    },
    "resources": [
      "bin/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/amverge-mini-logo.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFM0Y2M0JBREQ3QzEzMEUKUldRT0UzemR2bU0vcnFEdnVCQUFnendOWU42bWg2RWROMS9zd0VXRXNZakltMWN0OERUK0dib0MK",
      "endpoints": [
        "https://github.com/Anh9000/AMVerge-Plus/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
